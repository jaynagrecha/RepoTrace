# ── RepoTrace v2 configuration ───────────────────────────────────────────────

# GitHub / GitLab access (server-side tokens; never commit real values)
GITHUB_TOKEN=
GITLAB_TOKEN=

# ── Persistence (paid Render tier: mount a disk and point the DB at it) ──
# Create a Render persistent disk mounted at /var/data, then set:
REPOTRACE_DB_PATH=/var/data/repotrace.db

# ── Proxy / client-IP trust ──
# Render sits ONE proxy in front of the app and appends the real client IP as
# the rightmost X-Forwarded-For entry. Keep TRUST_PROXY=true on Render.
TRUST_PROXY=true
TRUSTED_PROXY_HOPS=1

# ── CORS ──
# Same-origin SPA can leave this empty. Otherwise comma-separate exact origins.
ALLOWED_ORIGINS=https://repotrace.onrender.com

# Public base URL for password-reset links in emails
APP_BASE_URL=https://repotrace.onrender.com
RESET_TOKEN_TTL_MIN=30

# Email OTP verification at registration
OTP_TTL_MIN=15
# Set DEBUG_OTP=1 in local dev to return the OTP in the API response (never in prod)
DEBUG_OTP=0

# ── Sessions ──
SESSION_TTL_HOURS=168

# ── Public launch controls ──
PUBLIC_MODE=false
FREE_DAILY_LIMIT=20
BURST_LIMIT_PER_MINUTE=12

# ── Admin (CHANGE BEFORE ANY PUBLIC DEPLOY — no default password) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Optional multi-admin JSON, e.g. {"alice":"pw1","bob":"pw2"}
ADMIN_USERS_JSON=

# ── Payments (Razorpay) ──
PAYMENT_PROVIDER=razorpay
PAYMENTS_ENABLED=true
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
# Required for live webhooks
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_UPI_FIRST=true
PAYMENT_PREFILL_EMAIL=
PAYMENT_PREFILL_CONTACT=
PRICE_PER_SEARCH=2

# ── UPI display (optional manual QR/deeplink path) ──
UPI_NAME=RepoTrace
UPI_ID=your-upi-id@bank
UPI_PAYMENT_NOTE=RepoTrace search
PAYMENT_NOTE=Free searches are limited. Pay to unlock a verified paid search.
UPI_QR_PATH=app/static/upi_qr.png

# ── VirusTotal hash enrichment (optional but recommended) ──
VT_API_KEY=
VT_LOOKUP_LIMIT=300
VT_LOOKUP_CONCURRENCY=3
VT_CACHE_TTL_SECONDS=604800
MAX_FILE_HASH_BYTES=5000000

# ── Watch scheduler (Phase 5) ──
WATCH_SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
WATCH_EMAIL_TO=

# ── Watch-mode email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
REPORT_TO_EMAIL=

# ── Optional enterprise/org GitHub token routing by email domain ──
# ORG_GITHUB_TOKENS_JSON={"wu.com":"github_pat_xxx","*":"github_pat_default"}
ORG_GITHUB_TOKENS_JSON=
ORG_GITHUB_TOKEN_DEFAULT=
