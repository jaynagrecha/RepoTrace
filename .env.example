GITHUB_TOKEN=github_pat_or_ghp_token_here
GITLAB_TOKEN=optional_gitlab_token_here

# Optional RepoTrace Watch Mode email alerts
WATCH_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# RepoTrace public-launch controls
# Keep PUBLIC_MODE=false for local/private use. Set true only when deploying publicly.
PUBLIC_MODE=false
FREE_DAILY_LIMIT=20
BURST_LIMIT_PER_MINUTE=12
PRICE_PER_SEARCH=2
UPI_NAME=RepoTrace
UPI_ID=your-upi-id@bank
UPI_PAYMENT_NOTE=RepoTrace search
PAYMENT_NOTE=Free searches are limited. Click Search ₹2 to unlock one verified paid search.

# Optional static fallback QR. Dynamic QR is generated from UPI_ID and PRICE_PER_SEARCH.
UPI_QR_PATH=app/static/upi_qr.png

# Admin usage panel credentials. Change before any public deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
TEST_ADMIN_USERNAME=tester
TEST_ADMIN_PASSWORD=
ADMIN_USERS_JSON=change-me-before-public-deploy

# Verified payment mode (Razorpay)
PAYMENT_PROVIDER=razorpay
PAYMENTS_ENABLED=true
# Use rzp_test_* keys locally. Switch to rzp_live_* only after Razorpay account/live activation.
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Strongly recommended for public/live deployments. Required by RepoTrace for live webhooks.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_optional_for_test_required_for_live_webhooks
RAZORPAY_UPI_FIRST=true
PAYMENT_PREFILL_EMAIL=
PAYMENT_PREFILL_CONTACT=

# Optional VirusTotal hash verdict enrichment
VT_API_KEY=
VT_LOOKUP_LIMIT=300
VT_LOOKUP_CONCURRENCY=3
MAX_FILE_HASH_BYTES=5000000

# Optional org/user login and report workflow
REPORT_TO_EMAIL=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# Optional enterprise/org token routing.
# Users register with an org email; RepoTrace chooses a server-side token by email domain.
# Example 1: direct domain env var for wu.com -> ORG_GITHUB_TOKEN_WU_COM
ORG_GITHUB_TOKEN_WU_COM=
# Example 2: JSON map for multiple domains. Keep secrets only in Render/.env, never commit real values.
# ORG_GITHUB_TOKENS_JSON={"wu.com":"github_pat_xxx","example.com":"github_pat_yyy","*":"github_pat_default"}
ORG_GITHUB_TOKENS_JSON=
ORG_GITHUB_TOKEN_DEFAULT=
